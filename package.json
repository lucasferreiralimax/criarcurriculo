{
  "name": "criarcurriculo",
  "version": "3.0.0",
  "author": "lucasferreiralimax (https://github.com/lucasferreiralimax)",
  "repository": "https://github.com/lucasferreiralimax/criarcurriculo",
  "bugs": {
    "url": "https://github.com/lucasferreiralimax/criarcurriculo/issues"
  },
  "scripts": {
    "serve": "vite preview",
    "build": "vite build",
    "test:unit": "vitest --environment jsdom",
    "test:e2e": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress open'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "dev": "vite",
    "preview": "vite preview --port 5050",
    "readme": "node -r esm readme.js",
    "test:e2e:ci": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress run'"
  },
  "dependencies": {
    "@mdi/font": "5.9.55",
    "pinia": "^2.0.13",
    "roboto-fontface": "*",
    "stylus": "^0.57.0",
    "vue": "^3.2.31",
    "vue-router": "^4.0.14",
    "vuetify": "^3.0.0-beta.0",
    "webfontloader": "^1.0.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.0",
    "@vitejs/plugin-vue": "^2.3.1",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.0.0-rc.18",
    "@vuetify/vite-plugin": "^1.0.0-alpha.0",
    "cypress": "^9.5.3",
    "eslint": "^8.5.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-vue": "^8.2.0",
    "esm": "^3.2.25",
    "jsdom": "^19.0.0",
    "prettier": "^2.5.1",
    "pug": "^3.0.2",
    "sass": "^1.38.0",
    "sass-loader": "^12.6.0",
    "start-server-and-test": "^1.14.0",
    "vite": "^2.9.1",
    "vitest": "^0.9.3",
    "vue-cli-plugin-vuetify": "~2.4.8",
    "vuetify-loader": "^2.0.0-alpha.0"
  }
}
